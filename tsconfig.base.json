{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@org/source"],
    "baseUrl": ".",
    "paths": {
      "@stylesync/utils": ["libs/shared/utils/index.ts"],
      "@stylesync/types": ["libs/shared/types/index.ts"],
      "@stylesync/models": ["libs/shared/models/src/index.ts"],
      "@stylesync/events": ["libs/events/index.ts"],
      "@stylesync/redis": ["libs/redis/index.ts"],
      "@stylesync/sentry": ["libs/logger/index.ts"],
      "@stylesync/db": ["libs/shared/storage/db/src/database.ts"],
      "@stylesync/orm": ["libs/shared/storage/db/index.ts"],
      "@stylesync/storage/db": ["libs/shared/storage/db/src/schema.ts"],
      "@stylesync/storage/blob": ["libs/shared/storage/blob/index.ts"]
    }
  }
}
